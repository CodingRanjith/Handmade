# Application
NODE_ENV=development
PORT=5000
APP_NAME=HandMade
APP_URL=https://handmade-i7gr.onrender.com
CLIENT_URL=https://handmadegif.netlify.app
API_PREFIX=/api/v1

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DB_SSL=true

# Supabase Project (new API keys)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWKS_URL=https://[YOUR-PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_STORAGE_BUCKET=handmade-assets

# Legacy keys (optional fallbacks)
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_IN_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=HandMade
SMTP_FROM_EMAIL=noreply@handmade.com

# Google OAuth (ready for client integration)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS
CORS_ORIGINS=https://handmadegif.netlify.app,http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info
